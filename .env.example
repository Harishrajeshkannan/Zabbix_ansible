# Zabbix API Configuration
VITE_ZABBIX_API_URL=https://your-zabbix-server.com/api_jsonrpc.php
VITE_ZABBIX_API_TOKEN=your_api_token_here

# Latest Zabbix agent version (fallback)
VITE_LATEST_AGENT_VERSION=7.0.0

# (Optional) External search API to fetch latest Zabbix agent version
VITE_AGENT_VERSION_SEARCH_API=https://your-search-api/latest-zabbix-agent

# (Optional) API key for the search API (sent as Bearer token)
VITE_AGENT_VERSION_SEARCH_API_KEY=your_search_api_key_here

# Backend SSH defaults (used for install + remote file manager)
# These are read by server/index.js (Node backend), not by Vite client.
SSH_USER=zabbix-deployment
SSH_PASSWORD=6S27k6AuWxPb
SSH_PORT=22
