# Zabbix API Configuration
VITE_ZABBIX_API_URL=https://your-zabbix-server.com/api_jsonrpc.php
VITE_ZABBIX_API_TOKEN=your_api_token_here

# Latest Zabbix agent version (fallback)
VITE_LATEST_AGENT_VERSION=7.0.0

# (Optional) External search API to fetch latest Zabbix agent version
VITE_AGENT_VERSION_SEARCH_API=https://your-search-api/latest-zabbix-agent

# (Optional) API key for the search API (sent as Bearer token)
VITE_AGENT_VERSION_SEARCH_API_KEY=your_search_api_key_here

# Ansible controller settings (used by backend to run playbooks)
# Example: set the path to ansible-playbook or inventory if needed
# ANSIBLE_PLAYBOOK_CMD=ansible-playbook
# ANSIBLE_INVENTORY_DIR=ansible/inventory

# Ansible SSH Credentials (required for remote host authentication)
# Username for SSH authentication to target hosts
ANSIBLE_SSH_USER=root

# SSH password for password-based authentication (leave empty if using key-based auth)
ANSIBLE_SSH_PASSWORD=your_ssh_password_here

# SSH port for remote hosts (default: 22)
ANSIBLE_SSH_PORT=22

# (Optional) Path to SSH private key file for key-based authentication
# If set, ANSIBLE_SSH_PRIVATE_KEY_FILE takes precedence over ANSIBLE_SSH_PASSWORD
# Example: /home/ansible/.ssh/id_rsa or C:\path\to\id_rsa
# ANSIBLE_SSH_PRIVATE_KEY_FILE=/path/to/private/key

# Note: For password-based auth to work without prompts, ensure 'sshpass' is installed on the controller
# OR use ANSIBLE_ASK_PASS=true to prompt for password interactively (not recommended for automation)
